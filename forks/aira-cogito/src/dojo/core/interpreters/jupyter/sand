# Modified for non-SLURM environments (local GPU workstation)

# Diagnostics (to stderr)
nvidia-smi >&2 2>/dev/null || echo "No GPU detected" >&2
df -hT / /tmp >&2 2>/dev/null
hostname -f >&2 2>/dev/null
apptainer instance list -a -j >&2 2>/dev/null

set -e

# Temp directory: use TMP_BASE_DIR if set, else /tmp/cogito_sand
if [[ -z "$TMP_BASE_DIR" ]]; then
    if [[ -n "$SLURM_JOBID" ]]; then
        TMP_BASE_DIR="/scratch/slurm_tmpdir/$SLURM_JOBID/"
    else
        TMP_BASE_DIR="/tmp/cogito_sand_$(id -u)"
    fi
fi
mkdir -p "$TMP_BASE_DIR"

# Memory limit (best-effort, non-fatal if ulimit fails)
ulimit -v 100000000 2>/dev/null || true  # 100GB

# Create unique temp dir and instance name
echo "Making tmp directory" >&2
TMP_DIR=$(mktemp -d -p "$TMP_BASE_DIR" sandbox-XXXXXXXXXX)
echo "Created temporary dir $TMP_DIR" >&2
INSTANCE_NAME=$(basename "$TMP_DIR")

# Hostname/IP for Jupyter Kernel Gateway
KG_IP=$(hostname -i 2>/dev/null || echo "127.0.0.1")
echo "Hostname: $(hostname -f 2>/dev/null || echo 'localhost')" >&2

# Cleanup on exit
cleanup() {
    echo "Stopping instance $INSTANCE_NAME ..." >&2
    apptainer instance stop "$INSTANCE_NAME" 2>/dev/null || true
    echo "Cleaning up $TMP_DIR ..." >&2
    if [[ -n "$TMP_DIR" && -d "$TMP_DIR" ]]; then
        rm -rf "$TMP_DIR"
        echo "Removed temporary directory $TMP_DIR" >&2
    fi
    exit 0
}

trap 'cleanup SIGINT'  SIGINT
trap 'cleanup SIGTERM' SIGTERM
trap 'cleanup EXIT'    EXIT

# Create overlay
echo "Creating overlay" >&2
if [[ "$IMAGE_OVERLAY" == "1" ]]; then
    OVERLAY_PATH="$TMP_DIR/overlay.sparse.img"
    apptainer overlay create --fakeroot --sparse --size 1048576 "$OVERLAY_PATH"
else
    OVERLAY_PATH="$TMP_DIR"
fi

# Superimage version default
if [ -z "$SUPERIMAGE_VERSION" ]; then
    SUPERIMAGE_VERSION=2025-05-02v2
fi

# Base overlays default
if [ -z "$BASE_OVERLAYS" ]; then
    BASE_OVERLAYS=""
fi

# Cache task data to tmp (for mlebench, optional for airsbench)
cache_to_tmp() {
    echo "Patching APPTAINER_BIND" >&2
    BASE="/shared/cache/dojo/tasks/mlebench"
    echo "Original: $APPTAINER_BIND" >&2
    ORIG=$(echo "$APPTAINER_BIND" | grep -Eo "(^|,)/.*?/shared/cache/dojo/tasks/mlebench/.*?/prepared/public" || true)
    [ -z "$ORIG" ] && return 0
    echo "Original path: $ORIG" >&2
    TASKNAME=$(basename "$(realpath "$ORIG/../..")")
    echo "TASKNAME: $TASKNAME" >&2

    NEW="$TMP_BASE_DIR/${ORIG}"
    DONE_MARKER="$NEW/.completed"

    APPTAINER_BIND="${APPTAINER_BIND//$ORIG/$NEW}"
    export APPTAINER_BIND
    echo "Rewrote APPTAINER_BIND to $APPTAINER_BIND" >&2

    if [ ! -f "$DONE_MARKER" ]; then
        TARBALL_PATH=$(realpath "$ORIG/../public.tar")
        if [ -f "$TARBALL_PATH" ]; then
            echo "Extracting $TARBALL_PATH to $NEW" >&2
            mkdir -p "$NEW"
            tar -xf "$TARBALL_PATH" -C "$NEW/.."
            touch "$DONE_MARKER"
        else
            echo "Tarball not found, copying directory" >&2
            if [ -n "$ORIG" ]; then
                echo "Copying $ORIG to $NEW" >&2
                mkdir -p "$NEW"
                cp -a "$ORIG"/. "$NEW"/
            fi
            : > "$DONE_MARKER"
        fi
    fi
}

cache_to_tmp

# Copy superimage to tmp if not already there
SIF_NAME="superimage.root.$SUPERIMAGE_VERSION.sif"
if [ ! -f "$TMP_BASE_DIR/$SIF_NAME" ]; then
    echo "Copying $SIF_NAME from $SUPERIMAGE_DIR to $TMP_BASE_DIR/" >&2
    cp "${SUPERIMAGE_DIR}/${SIF_NAME}" "$TMP_BASE_DIR/progress.$SIF_NAME"
    mv "$TMP_BASE_DIR/progress.$SIF_NAME" "$TMP_BASE_DIR/$SIF_NAME"
fi

# Launch apptainer instance
apptainer instance run \
    --containall \
    --cleanenv \
    --no-home \
    $BASE_OVERLAYS \
    --overlay "$OVERLAY_PATH" \
    --env SSH_PUBLIC_KEY="$SSH_PUBLIC_KEY" \
    --env KG_IP="$KG_IP" \
    --env PYTHONUNBUFFERED=1 \
    --env WANDB_DISABLED=1 \
    --env TQDM_DISABLE=1 \
    --env HTTP_PROXY="${RAD_HTTP_PROXY}" \
    --env HTTPS_PROXY="${RAD_HTTPS_PROXY}" \
    --env NO_PROXY="${RAD_NO_PROXY}" \
    --env HF_TOKEN="${RAD_HF_TOKEN}" \
    --env HF_ENDPOINT="${RAD_HF_ENDPOINT}" \
    --env HF_HUB_VERBOSITY="${RAD_HF_HUB_VERBOSITY}" \
    --env HF_HUB_OFFLINE="${RAD_HF_HUB_OFFLINE}" \
    --env HF_HUB_DISABLE_PROGRESS_BARS=1 \
    --env HF_HUB_DISABLE_TELEMETRY=1 \
    --env CUDA_LAUNCH_BLOCKING=1 \
    --env NLTK_DATA="${RAD_NLTK_DATA}" \
    --env TF_CPP_MIN_LOG_LEVEL=3 \
    --nv \
    --fakeroot \
    "$TMP_BASE_DIR/$SIF_NAME" \
    "$INSTANCE_NAME" \
    "$@"

echo "After starting"

# Pipe instance logs
LOG_DIR="$HOME/.apptainer/instances/logs/$(hostname)/$USER"
if [ -d "$LOG_DIR" ]; then
    tail -f "$LOG_DIR/$INSTANCE_NAME.err" >&2
else
    echo "No log dir found at $LOG_DIR, instance may have started without logging" >&2
fi
