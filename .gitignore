# ==========================
# research_society (root)
# Keep code + configs. Ignore secrets, environments, data, and run artifacts.
# ==========================

# --- Secrets / environment files ---
.env
.env.*
.envrc

# common key/cert files
*.pem
*.key
*.p12
*.pfx

# --- Python bytecode / caches ---
__pycache__/
*.py[cod]
*$py.class

.mypy_cache/
.pytest_cache/
.ruff_cache/
.hypothesis/
.coverage
.coverage.*
htmlcov/

# --- Python packaging ---
build/
dist/
*.egg-info/
.eggs/

# --- Virtual envs (local) ---
.venv/
venv/
ENV/
env/
.env.bak/
venv.bak/

# --- Jupyter ---
.ipynb_checkpoints/

# --- Editors / OS ---
.vscode/
.idea/
.cursor/
.claude/
.cursorignore
.cursorindexingignore
.DS_Store
Thumbs.db
*.swp
*.swo

# --- Claude Code local state ---
.claude/

# --- Hydra / experiment outputs (anywhere) ---
**/outputs/
**/multirun/
**/.hydra/
**/*hydra_logs*/

# --- Run artifacts / logs (anywhere) ---
**/logs/
**/*.log
**/wandb/

# --- Workspaces / scratch dirs ---
**/workspace/
**/workspaces/
**/_scratch*

# --- Common caches / downloaded artifacts ---
**/.cache/
**/cache/
**/tmp/

# --- Apptainer / docker artifacts ---
*.sif
*.img
*.sqsh

# --- ML checkpoints / large artifacts (avoid committing models) ---
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx

# --- Common dataset formats (avoid committing raw data) ---
*.parquet
*.arrow
*.feather
*.h5
*.hdf5
*.npy
*.npz

# --- Dojo / MLEBench specific ---
# Ignore all competition folders under data/mlebench, but keep utils and _splits
**/data/mlebench/*/
!**/data/mlebench/utils/
!**/data/mlebench/utils/**
!**/data/mlebench/_splits/
!**/data/mlebench/_splits/**

# Ignore embedded mle-bench source checkout (large vendored repo)
**/src/dojo/tasks/mlebench/mle-bench/

# --- AIRS-Bench repo testing artifacts ---
# Prevent accidentally committing task CSVs that may be generated during tests
**/airsbench/tasks/rad/*/*.csv

# --- Airs-bench datasets (all downloaded data, keep code only) ---
forks/airs-bench/datasets/
**/datasets/datasets_download_location/
**/datasets/datasets_download_location_prepared/
**/datasets/hf_datasets_sample.csv

# --- MLGym artifacts ---
models/
trajectories/*
!trajectories/mlgym_bench_v0/
trajectories/**/*.log
trajectories/**/*.pdf
trajectories/**/args.yaml

# --- Do not commit generated submissions ---
submission.csv
**/submission.csv


# --- aira-dojo / aira-dojo-baseline large runtime artifacts ---
forks/aira-dojo/shared/
forks/aira-dojo/logs_*/
forks/aira-dojo-baseline/shared/
forks/aira-dojo-baseline/logs_baseline_*/
forks/aira-dojo-baseline/launch_log*.txt
forks/aira-dojo/launch_log*.txt

# --- upstream (external, not tracked) ---
upstream/**
